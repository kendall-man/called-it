# ══════════════════════════════════════════════════════════════════════════
# STAGING TWIN — copy to `.env` in THIS WORKTREE and fill the blanks.
# Real Telegram + real GLM + real devnet SOL + throwaway Supabase;
# the ONLY fake is the World Cup itself (mockline on localhost:8791).
# Full walkthrough: STAGING.md
# ══════════════════════════════════════════════════════════════════════════

# ── Engine ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=            # NEW throwaway bot from @BotFather (never the prod bot)
GLM_API_KEY=                   # reuse your existing key — z.ai/manage-apikey/apikey-list
GLM_BASE_URL=https://api.z.ai/api/anthropic
SUPABASE_URL=                  # THROWAWAY project: https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # that project's service_role key

# Engine HTTP + Telegram ingress.
#   poll    → engine-only mode: cards, stakes, settlement (no Callie chat)
#   webhook → single-ingress full product: eve owns the webhook, engine
#             receives updates via /api/telegram-update (needs the tunnel)
ENGINE_API_TOKEN=              # long random string, e.g. `openssl rand -hex 24`
TELEGRAM_INGRESS=poll
WAGER_MODE_ENABLED=true
# "No real devnet" mode: play-money lamports auto-credited on each member's
# first stake — nobody needs a wallet, faucet, or deposit. STAGING ONLY;
# 0/unset anywhere production-like. Treasury must cover grant × members.
WAGER_STAGING_GRANT_LAMPORTS=200000000

# ── TxLINE → mockline (the one mocked boundary) ───────────────────────────
TXLINE_API_BASE=http://localhost:8791
TXLINE_GUEST_JWT=mock-guest-jwt
TXLINE_API_TOKEN=mock-api-token

# ── Solana devnet (real chain, worthless token) ───────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_B58=            # from `pnpm staging:keys` — proof wallet
WAGER_TREASURY_KEYPAIR_B58=    # from `pnpm staging:keys` — MUST differ from above
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Receipt links posted in chat. localhost is fine for solo testing on this
# Mac; deploy apps/web to a staging Vercel project for friends' phones.
WEB_BASE_URL=http://localhost:3020

# ── Concierge (webhook mode only) ─────────────────────────────────────────
ENGINE_API_URL=http://localhost:8790
CONCIERGE_BOT_USERNAME=         # the throwaway bot's username, no @
TELEGRAM_WEBHOOK_SECRET_TOKEN=  # random string; also passed to setWebhook
AGENT_LIVE=0

# ── Web (apps/web/.env.local — public values from the throwaway project) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
