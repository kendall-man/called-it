{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      // Canonical domain types, imported type-only (erased at build) so the
      // web bundle never needs market-engine's dist output to exist.
      // NOTE: `solana-verify-bridge` deliberately has NO paths entry — its
      // types are ambient (types/solana-verify-bridge.d.ts) so the webpack
      // alias in next.config.ts alone decides what gets bundled.
      "@calledit/market-engine": ["../../packages/market-engine/src/types.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
