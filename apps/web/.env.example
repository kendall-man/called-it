# Optional public read-only providers. Configure each pair together.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=
NEXT_PUBLIC_WAGER_TREASURY_PUBKEY=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WAGER_CUSTODY_MODE=legacy
NEXT_PUBLIC_ESCROW_PROGRAM_ID=
NEXT_PUBLIC_ESCROW_CANONICAL_USDC_MINT=
NEXT_PUBLIC_ESCROW_GENESIS_HASH=

# Required for production builds.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_STARTGROUP=calledit_v1

# Server-only wallet bridge values. Never add NEXT_PUBLIC_ prefixes.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SOLANA_RPC_URL=
CONCIERGE_WALLET_API_URL=
WEB_CONCIERGE_TOKEN=
# Lowercase SHA-256 fingerprints used only to prove the bridge token differs
# from every engine route token. They are not bearer credentials.
ENGINE_CONCIERGE_TOKEN_SHA256=
ENGINE_TELEGRAM_TOKEN_SHA256=
ENGINE_OPS_TOKEN_SHA256=
ESCROW_GENESIS_HASH=
WEB_BASE_URL=http://localhost:3000
WALLET_LINK_DOMAIN=localhost
ANALYTICS_HMAC_SECRET=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWT_VERIFICATION_KEY=
WALLET_AUTH_PRIVATE_KEY=
WALLET_AUTH_KEY_ID=calledit-wallet-v1

STARTER_GRANTS_ENABLED=false
WALLET_MINIAPP_ENABLED=false
WALLET_PROVIDER=disabled
STAKE_ACCEPTANCE_ENABLED=false
