# Optional public read-only providers. Configure each pair together.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=
NEXT_PUBLIC_WAGER_TREASURY_PUBKEY=
NEXT_PUBLIC_PRIVY_APP_ID=

# Required for production builds.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_STARTGROUP=calledit_v1

# Server-only wallet bridge values. Never add NEXT_PUBLIC_ prefixes.
CONCIERGE_WALLET_API_URL=
WEB_CONCIERGE_TOKEN=
WEB_BASE_URL=http://localhost:3000
WALLET_LINK_DOMAIN=localhost
ANALYTICS_HMAC_SECRET=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWT_VERIFICATION_KEY=
WALLET_AUTH_PRIVATE_KEY=
WALLET_AUTH_KEY_ID=calledit-wallet-v1

STARTER_GRANTS_ENABLED=false
WALLET_MINIAPP_ENABLED=false
WALLET_PROVIDER=disabled
STAKE_ACCEPTANCE_ENABLED=false
