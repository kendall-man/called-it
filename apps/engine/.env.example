DEPLOYMENT_ENV=development

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_INGRESS=poll
BETA_ALLOWED_GROUP_IDS=

GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

ENGINE_CONCIERGE_TOKEN=
ENGINE_TELEGRAM_TOKEN=
ENGINE_OPS_TOKEN=
# Lowercase SHA-256 of the distinct web-to-concierge bridge token; audit only.
WEB_CONCIERGE_TOKEN_SHA256=

TXLINE_API_BASE=
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

SOLANA_RPC_URL=
SOLANA_KEYPAIR_B58=
TXORACLE_PROGRAM_ID=
TXL_MINT=

WEB_BASE_URL=http://localhost:3000
WALLET_LINK_DOMAIN=localhost
ANALYTICS_HMAC_SECRET=

# Required in staging/production: disabled | starter_only | funded
WAGER_RUNTIME_MODE=disabled
# New-market custody routing: legacy | escrow. Existing liabilities stay recoverable.
WAGER_CUSTODY_MODE=legacy
# Legacy local selector. In staging/production use false for disabled, true otherwise.
WAGER_MODE_ENABLED=false
WAGER_TREASURY_KEYPAIR_B58=
WAGER_OPS_CHAT_ID=
TREASURY_COVERAGE_ENFORCED=false

# Escrow custody contract. ESCROW_ALLOWED_GROUP_IDS may be empty only while
# STAKE_ACCEPTANCE_ENABLED=false so recovery can continue with intake disabled.
ESCROW_ALLOWED_GROUP_IDS=
ESCROW_PROGRAM_ID=
ESCROW_GENESIS_HASH=
ESCROW_CANONICAL_USDC_MINT=
ESCROW_CLASSIC_TOKEN_PROGRAM_ID=
ESCROW_ORACLE_SET_PDA=
ESCROW_ORACLE_SET_EPOCH=
ESCROW_ORACLE_THRESHOLD=2
ESCROW_ORACLE_SIGNERS=
# Configure exactly one oracle signer provider. Local keypairs are devnet-only.
ESCROW_ORACLE_SIGNER_ENDPOINTS_JSON=
ESCROW_ORACLE_LOCAL_KEYPAIRS_B58_JSON=
ESCROW_INDEXER_MAX_LAG_SLOTS=32
# Shared cadence for relayer, attestation, and finalized-indexer work.
ESCROW_WORKER_INTERVAL_MS=5000
ESCROW_CONFIG_AUTHORITY=
ESCROW_PAUSE_AUTHORITY=
ESCROW_MARKET_CREATION_AUTHORITY=
# Configure exactly one market authority signer. Local key material is devnet-only.
ESCROW_MARKET_AUTHORITY_KEYPAIR_B58=
ESCROW_MARKET_AUTHORITY_SIGNER_ENDPOINT_JSON=
ESCROW_UPGRADE_AUTHORITY=
ESCROW_RESIDUAL_RECIPIENT=
ESCROW_RELAYER_KEYPAIR_B58=
ESCROW_FEED_OPERATOR_KEYPAIR_B58=
ESCROW_MAINNET_ENABLED=false

# Starter grants require starter_only; funded must keep this false.
STARTER_GRANTS_ENABLED=false
WALLET_MINIAPP_ENABLED=false
STAKE_ACCEPTANCE_ENABLED=false

QUEUE_LEASE_MS=30000
QUEUE_MAX_ATTEMPTS=8
QUEUE_RETRY_BASE_MS=500
QUEUE_RETRY_MAX_MS=30000
READINESS_CHECK_TIMEOUT_MS=5000
READINESS_FEED_MAX_AGE_MS=60000
READINESS_WORKER_MAX_AGE_MS=30000
READINESS_INGRESS_MAX_AGE_MS=30000
READINESS_PROOF_MAX_BACKLOG=100
READINESS_PROOF_MAX_OLDEST_AGE_MS=600000
READINESS_SETTLEMENT_MAX_BACKLOG=100
READINESS_SETTLEMENT_MAX_OLDEST_AGE_MS=120000
SHUTDOWN_DRAIN_TIMEOUT_MS=12000
PORT=8790
