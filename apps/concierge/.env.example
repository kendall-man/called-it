# Callie — Called It concierge (eve app)
# Copy to .env for local dev; set the same names on the Vercel project.

# Model (GLM via its Anthropic-compatible endpoint — same provider as the engine)
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic

# Telegram (a SEPARATE bot from the engine's — BotFather /newbot,
# then /setprivacy → Disable so @mentions reach the webhook)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
CONCIERGE_BOT_USERNAME=

# Engine integration surface (Railway engine's HTTP API)
ENGINE_API_URL=
ENGINE_API_TOKEN=
