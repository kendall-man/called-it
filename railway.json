{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm exec turbo run build --filter=@calledit/engine..."
  },
  "deploy": {
    "startCommand": "pnpm --filter @calledit/engine start",
    "healthcheckPath": "/api/ready",
    "healthcheckTimeout": 30,
    "drainingSeconds": "15",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
