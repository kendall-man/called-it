{
  "name": "@calledit/solana",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    },
    "./message-signing": {
      "types": "./dist/message-signing.d.ts",
      "default": "./dist/message-signing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@solana/web3.js": "^1.95.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
