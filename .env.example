# Complete local inventory. App-specific files define each deployment's subset.

# Shared environment identity and public origin
DEPLOYMENT_ENV=development
WEB_BASE_URL=http://localhost:3000
WALLET_LINK_DOMAIN=localhost

# Telegram webhook identity
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_INGRESS=poll
# Comma-separated negative Telegram group IDs. Required in staging/production.
BETA_ALLOWED_GROUP_IDS=

# GLM provider
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic

# Engine database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Engine route-scoped credentials; all three values must differ
ENGINE_CONCIERGE_TOKEN=
ENGINE_TELEGRAM_TOKEN=
ENGINE_OPS_TOKEN=
ENGINE_PRIVATE_API_URL=

# Cross-runtime SHA-256 fingerprints for uniqueness checks; never route credentials
ENGINE_CONCIERGE_TOKEN_SHA256=
ENGINE_TELEGRAM_TOKEN_SHA256=
ENGINE_OPS_TOKEN_SHA256=
WEB_CONCIERGE_TOKEN_SHA256=

# Browser-to-concierge server bridge; never prefix these with NEXT_PUBLIC_
CONCIERGE_WALLET_API_URL=
WEB_CONCIERGE_TOKEN=

# TxLINE
TXLINE_API_BASE=
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Solana network and proof submission. mainnet-beta requires production + funded mode,
# starter grants off, stake acceptance on, and treasury coverage enforcement on.
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=
SOLANA_KEYPAIR_B58=
TXORACLE_PROGRAM_ID=
TXL_MINT=

# Wager runtime: disabled | starter_only | funded. Required in staging/production.
WAGER_RUNTIME_MODE=disabled
# Legacy local selector. In staging/production use false for disabled, true otherwise.
WAGER_MODE_ENABLED=false
# Dedicated funded-runtime treasury and dynamic coverage gate
WAGER_TREASURY_KEYPAIR_B58=
WAGER_OPS_CHAT_ID=
TREASURY_COVERAGE_ENFORCED=false

# Starter grants require starter_only; funded must keep this false.
# Grant amount and cap live only in the database.
STARTER_GRANTS_ENABLED=false
WALLET_MINIAPP_ENABLED=false
STAKE_ACCEPTANCE_ENABLED=false

# Session keyring. Masters are canonical base64 for exactly 32 random bytes.
ACCOUNT_SESSION_KEY_CURRENT=
ACCOUNT_SESSION_KEY_CURRENT_KID=
# Previous fields are an all-or-none tuple used for at most ten minutes.
ACCOUNT_SESSION_KEY_PREVIOUS=
ACCOUNT_SESSION_KEY_PREVIOUS_KID=
ACCOUNT_SESSION_KEY_PREVIOUS_EXPIRES_AT=

# Pseudonymous analytics key: canonical base64 for exactly 32 random bytes
ANALYTICS_HMAC_SECRET=

# Engine queue, readiness, and drain thresholds in milliseconds unless noted
QUEUE_LEASE_MS=30000
QUEUE_MAX_ATTEMPTS=8
QUEUE_RETRY_BASE_MS=500
QUEUE_RETRY_MAX_MS=30000
READINESS_CHECK_TIMEOUT_MS=5000
READINESS_FEED_MAX_AGE_MS=60000
READINESS_WORKER_MAX_AGE_MS=30000
READINESS_INGRESS_MAX_AGE_MS=30000
READINESS_PROOF_MAX_BACKLOG=100
READINESS_PROOF_MAX_OLDEST_AGE_MS=600000
READINESS_SETTLEMENT_MAX_BACKLOG=100
READINESS_SETTLEMENT_MAX_OLDEST_AGE_MS=120000
SHUTDOWN_DRAIN_TIMEOUT_MS=12000

# Concierge readiness thresholds
READINESS_ENGINE_TIMEOUT_MS=3000

# Service port. Use 8790 for engine or 8080 for concierge in app-local env.
PORT=

# Web public values only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_STARTGROUP=calledit_v1
