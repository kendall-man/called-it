# ── Engine (apps/engine) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=            # from @BotFather
GLM_API_KEY=                   # GLM (Z.ai) key — z.ai/manage-apikey/apikey-list
GLM_BASE_URL=https://api.z.ai/api/anthropic   # Anthropic-compatible GLM endpoint
ANTHROPIC_API_KEY=             # legacy fallback accepted by the agent client
SUPABASE_URL=                  # https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # service_role key (engine only, never in web)

# Engine HTTP and Telegram ingress
ENGINE_API_TOKEN=              # shared bearer token for engine/concierge
TELEGRAM_INGRESS=poll           # poll or webhook
WAGER_MODE_ENABLED=false

# TxLINE devnet (filled by `pnpm bootstrap:txline` after on-chain subscribe)
TXLINE_API_BASE=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_B58=            # server hot wallet secret key, base58 (devnet only)
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Web page base (used in Telegram card links)
WEB_BASE_URL=http://localhost:3000

# ── Concierge (apps/concierge) ──────────────────────────────────────────
ENGINE_API_URL=http://localhost:8790
CONCIERGE_BOT_USERNAME=         # bot username without the @
TELEGRAM_WEBHOOK_SECRET_TOKEN=  # Telegram webhook secret token
AGENT_LIVE=0                    # set to 1 only for opt-in live model tests

# ── Web (apps/web) — public values only ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
