# Complete local inventory. App-specific files define each deployment's subset.

# Shared environment identity and public origin
DEPLOYMENT_ENV=development
WEB_BASE_URL=http://localhost:3000
WALLET_LINK_DOMAIN=localhost

# Telegram server identity and Mini App initData validation; never expose client-side
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_INGRESS=poll
# Optional direct-link Mini App short name from BotFather /newapp on this bot
# (Web App URL = <WEB_BASE_URL>/app; short name gives t.me/<bot>/<short>).
# Setting it activates in-group signing buttons on escrow offer cards; leave
# empty to keep the callback-button + private-chat signing flow unchanged.
TELEGRAM_MINIAPP_SHORT_NAME=
# Comma-separated negative Telegram group IDs. Required in staging/production
# unless PUBLIC_BETA_ENABLED=true.
BETA_ALLOWED_GROUP_IDS=
PUBLIC_BETA_ENABLED=false

# GLM provider
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic

# Engine database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Engine route-scoped credentials; all three values must differ
ENGINE_CONCIERGE_TOKEN=
ENGINE_TELEGRAM_TOKEN=
ENGINE_OPS_TOKEN=
ENGINE_PRIVATE_API_URL=

# Cross-runtime SHA-256 fingerprints for uniqueness checks; never route credentials
ENGINE_CONCIERGE_TOKEN_SHA256=
ENGINE_TELEGRAM_TOKEN_SHA256=
ENGINE_OPS_TOKEN_SHA256=
WEB_CONCIERGE_TOKEN_SHA256=

# Browser-to-concierge server bridge; never prefix these with NEXT_PUBLIC_
CONCIERGE_WALLET_API_URL=
WEB_CONCIERGE_TOKEN=

# TxLINE
TXLINE_API_BASE=
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Solana network and proof submission. mainnet-beta requires production + funded mode,
# starter grants off, and stake acceptance on. Legacy custody additionally requires
# treasury coverage; escrow custody requires ESCROW_MAINNET_ENABLED.
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=
SOLANA_KEYPAIR_B58=
TXORACLE_PROGRAM_ID=
TXL_MINT=

# Wager runtime: disabled | starter_only | funded. Required in staging/production.
WAGER_RUNTIME_MODE=disabled
# New-market custody routing: legacy | escrow. Existing legacy balances remain withdrawable.
WAGER_CUSTODY_MODE=legacy
# Legacy local selector. In staging/production use false for disabled, true otherwise.
WAGER_MODE_ENABLED=false
# Legacy-custody treasury and dynamic coverage gate. Leave both unset/false for escrow.
WAGER_TREASURY_KEYPAIR_B58=
WAGER_OPS_CHAT_ID=
TREASURY_COVERAGE_ENFORCED=false

# Escrow V1. Required only when WAGER_CUSTODY_MODE=escrow. The group allowlist
# may be empty only while STAKE_ACCEPTANCE_ENABLED=false so recovery stays bootable.
# Devnet uses the repository-pinned SDK identity. A separate mainnet Anchor build
# identity is created only at the explicit approval gate; this repo does not pre-create it.
# Keep mainnet disabled until the reviewed deployment and authority gate is approved.
ESCROW_ALLOWED_GROUP_IDS=
ESCROW_PROGRAM_ID=
ESCROW_GENESIS_HASH=
ESCROW_CANONICAL_USDC_MINT=
ESCROW_CLASSIC_TOKEN_PROGRAM_ID=
ESCROW_ORACLE_SET_PDA=
ESCROW_ORACLE_SET_EPOCH=
ESCROW_ORACLE_THRESHOLD=2
ESCROW_ORACLE_SIGNERS=
# Exactly one oracle signer provider: three independent HTTPS endpoints, or
# three local devnet-only keypairs. Values are JSON arrays.
ESCROW_ORACLE_SIGNER_ENDPOINTS_JSON=
ESCROW_ORACLE_LOCAL_KEYPAIRS_B58_JSON=
ESCROW_INDEXER_MAX_LAG_SLOTS=32
# Keep below public-RPC per-method burst limits so every cycle advances its cursor.
ESCROW_INDEXER_PAGE_SIZE=10
# Shared cadence for relayer, attestation, and finalized-indexer work.
ESCROW_WORKER_INTERVAL_MS=5000
ESCROW_CONFIG_AUTHORITY=
ESCROW_PAUSE_AUTHORITY=
ESCROW_MARKET_CREATION_AUTHORITY=
# Exactly one market-creation signer provider. Local key material is devnet-only;
# the mainnet HTTPS endpoint must include its bearer token in the JSON object.
ESCROW_MARKET_AUTHORITY_KEYPAIR_B58=
ESCROW_MARKET_AUTHORITY_SIGNER_ENDPOINT_JSON=
ESCROW_UPGRADE_AUTHORITY=
ESCROW_RESIDUAL_RECIPIENT=
ESCROW_RELAYER_KEYPAIR_B58=
ESCROW_FEED_OPERATOR_KEYPAIR_B58=
ESCROW_MAINNET_ENABLED=false

# Starter grants require starter_only; funded must keep this false.
# Grant amount and cap live only in the database.
STARTER_GRANTS_ENABLED=false
WALLET_MINIAPP_ENABLED=false
WALLET_PROVIDER=disabled
STAKE_ACCEPTANCE_ENABLED=false
# Two-step interactive stake ladder (side tap -> value ladder -> sign). OFF keeps
# the single-tap flow byte-for-byte. Turn on only after the engine is deployed
# ahead of web (the session schema accepts both the legacy and amountCode bodies).
STAKE_LADDER_ENABLED=false

# Privy Telegram authentication and user-owned Solana wallets. Use separate
# Privy apps for devnet and mainnet. Secrets must never use NEXT_PUBLIC_.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWT_VERIFICATION_KEY=
WALLET_AUTH_PRIVATE_KEY=
WALLET_AUTH_KEY_ID=calledit-wallet-v1

# Session keyring. Masters are canonical base64 for exactly 32 random bytes.
ACCOUNT_SESSION_KEY_CURRENT=
ACCOUNT_SESSION_KEY_CURRENT_KID=
# Previous fields are an all-or-none tuple used for at most ten minutes.
ACCOUNT_SESSION_KEY_PREVIOUS=
ACCOUNT_SESSION_KEY_PREVIOUS_KID=
ACCOUNT_SESSION_KEY_PREVIOUS_EXPIRES_AT=

# Pseudonymous analytics key: canonical base64 for exactly 32 random bytes
ANALYTICS_HMAC_SECRET=

# Engine queue, readiness, and drain thresholds in milliseconds unless noted
QUEUE_LEASE_MS=30000
QUEUE_MAX_ATTEMPTS=8
QUEUE_RETRY_BASE_MS=500
QUEUE_RETRY_MAX_MS=30000
READINESS_CHECK_TIMEOUT_MS=5000
READINESS_FEED_MAX_AGE_MS=60000
READINESS_WORKER_MAX_AGE_MS=30000
READINESS_INGRESS_MAX_AGE_MS=30000
READINESS_PROOF_MAX_BACKLOG=100
READINESS_PROOF_MAX_OLDEST_AGE_MS=600000
READINESS_SETTLEMENT_MAX_BACKLOG=100
READINESS_SETTLEMENT_MAX_OLDEST_AGE_MS=120000
SHUTDOWN_DRAIN_TIMEOUT_MS=12000

# Concierge readiness thresholds
READINESS_ENGINE_TIMEOUT_MS=3000

# Service port. Use 8790 for engine or 8080 for concierge in app-local env.
PORT=

# Web public values only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_TXORACLE_PROGRAM_ID=
NEXT_PUBLIC_WAGER_TREASURY_PUBKEY=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_STARTGROUP=calledit_v1
