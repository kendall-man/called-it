{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://called.it/schemas/escrow/build-manifest-v1.json",
  "title": "Called It escrow deterministic build manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceCommit", "programId", "sbfSha256", "idlSha256", "sourceSha256", "lockSha256"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" },
    "programId": { "$ref": "#/$defs/pubkey" },
    "sbfSha256": { "$ref": "#/$defs/sha256" },
    "idlSha256": { "$ref": "#/$defs/sha256" },
    "sourceSha256": { "$ref": "#/$defs/sha256" },
    "lockSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "pubkey": { "type": "string", "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
