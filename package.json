{
  "name": "calledit",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "typecheck:product-copy": "tsc -p tsconfig.product-copy.json",
    "verify:product-copy": "pnpm run typecheck:product-copy && tsx --test scripts/check-product-copy.test.ts && tsx scripts/check-product-copy.ts",
    "bootstrap:txline": "tsx scripts/bootstrap-txline.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
